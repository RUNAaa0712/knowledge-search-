# Discord application settings
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Optional: commands are registered to this guild immediately.
# If empty, commands are registered globally and can take time to appear.
DISCORD_GUILD_ID=

# Gemini API key from Google AI Studio.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Forum channels to use as the knowledge base.
# kind can be question, bug, feature, or other.
KNOWLEDGE_FORUMS=[{"id":"123456789012345678","name":"質問","kind":"question"},{"id":"234567890123456789","name":"バグ報告","kind":"bug"},{"id":"345678901234567890","name":"機能要望","kind":"feature"}]

# Local cache directory. Keep this out of git because it contains server content.
KNOWLEDGE_STORE_PATH=data/knowledge-store

# Search tuning
SEARCH_RESULT_LIMIT=8
SYNC_THREAD_LIMIT=0

# Comma-separated Discord user IDs allowed to run /sync-knowledge.
SYNC_ALLOWED_USER_IDS=

# If true, the bot checks newly created forum posts and replies when similar posts already exist.
ENABLE_THREAD_DUPLICATE_REPLY=true
