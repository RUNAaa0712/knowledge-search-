{
  "name": "knowledge-search-discord-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Discord forum knowledge search bot powered by Gemini.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "register": "node src/register-commands.js",
    "debug:search": "node src/debug/search-cache.js",
    "check": "find src -name '*.js' -exec node --check {} \\;",
    "test": "node --test \"src/**/*.test.js\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.7"
  },
  "overrides": {
    "undici": "^6.27.0"
  }
}
